postwriter.app {
	root * /var/www/postwriter

	# Serve actual files (epub, assets, etc.) directly
	@fileExists file
	handle @fileExists {
		file_server
	}

	# SPA fallback for everything else
	handle {
		rewrite * /index.html
		file_server
	}

	# Cache static assets aggressively
	@static path /assets/*
	header @static Cache-Control "public, max-age=31536000, immutable"

	# Security headers
	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
	}

	# Compression
	encode gzip zstd
}
